# Copia este archivo a .env.local y rellena los valores reales.
# .env.local NO se sube a git; este .env.example sí (no debe contener secretos).

# Clave de API de Resend (https://resend.com/api-keys)
RESEND_API_KEY=

# Email donde quieres recibir las consultas del formulario
CONTACT_TO_EMAIL=andreagonzpsicologia@gmail.com

# Remitente de los emails. Pruebas: onboarding@resend.dev
# Producción (con dominio verificado): "Web Andrea <hola@tudominio.com>"
CONTACT_FROM_EMAIL=Web Andrea González <onboarding@resend.dev>
